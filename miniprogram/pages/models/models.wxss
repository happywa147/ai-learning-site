/* pages/models/models.wxss */
/* 模型对比页面样式 */

.page-header {
  padding: 20rpx 8rpx 24rpx;
}

/* ========== 决策树入口 ========== */
.tree-entry {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #722F37, #8B4513);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(114, 47, 55, 0.2);
}

.tree-entry-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.tree-entry-text {
  flex: 1;
}

.tree-entry-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.tree-entry-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

.tree-entry-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 700;
}

/* ========== 筛选栏 ========== */
.filter-bar {
  display: flex;
  white-space: nowrap;
  padding: 8rpx 0 20rpx;
}

.filter-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #8B7355;
  background: #fff;
  border: 2rpx solid #E8DFD0;
}

.filter-item.active {
  background: #722F37;
  color: #fff;
  border-color: #722F37;
}

/* ========== 排序栏 ========== */
.sort-bar {
  display: flex;
  align-items: center;
  padding: 0 8rpx 24rpx;
  gap: 16rpx;
}

.sort-label {
  font-size: 26rpx;
  color: #8B7355;
}

.sort-item {
  font-size: 26rpx;
  color: #8B7355;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.sort-item.active {
  color: #722F37;
  font-weight: 700;
  background: #FAF6EF;
}

/* ========== 模型卡片 ========== */
.model-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.model-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(114, 47, 55, 0.08);
}

.model-card:active {
  transform: scale(0.98);
}

.model-card-top {
  margin-bottom: 20rpx;
}

.model-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.model-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #3D2817;
}

.model-desc {
  font-size: 26rpx;
  color: #8B7355;
  line-height: 1.5;
}

.model-card-bottom {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-top: 1rpx solid #F0EBE0;
  border-bottom: 1rpx solid #F0EBE0;
}

.model-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #722F37;
}

.stat-label {
  font-size: 22rpx;
  color: #8B7355;
  margin-top: 4rpx;
}

.model-modalities {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.modality-tag {
  font-size: 22rpx;
  color: #8B4513;
  background: #F5F0E8;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

.modality-tag.large {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
}

/* ========== 模型详情弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-content {
  width: 100%;
  max-height: 85vh;
  background: #FAF6EF;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #E8DFD0;
  flex-shrink: 0;
}

.modal-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D2817;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 32rpx;
  color: #8B7355;
}

.modal-body {
  padding: 32rpx;
  flex: 1;
}

.modal-desc {
  display: block;
  font-size: 28rpx;
  color: #3D2817;
  line-height: 1.7;
  margin-bottom: 32rpx;
}

/* 详情指标 */
.detail-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.detail-stat-item {
  flex: 1;
  min-width: 40%;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.detail-stat-value {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #722F37;
}

.detail-stat-label {
  display: block;
  font-size: 22rpx;
  color: #8B7355;
  margin-top: 4rpx;
}

/* 详情区块 */
.detail-section {
  margin-bottom: 32rpx;
}

.detail-section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2817;
  margin-bottom: 16rpx;
}

.detail-list-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.list-bullet {
  font-size: 28rpx;
  margin-right: 12rpx;
  line-height: 1.7;
}

.list-bullet.green { color: #2E7D32; }
.list-bullet.orange { color: #F57F17; }

.detail-list-text {
  flex: 1;
  font-size: 26rpx;
  color: #3D2817;
  line-height: 1.7;
}

.modality-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.usecase-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.usecase-tag {
  font-size: 24rpx;
  color: #722F37;
  background: #fff;
  border: 1rpx solid #E8DFD0;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
}

/* ========== 决策树弹窗 ========== */
.tree-modal {
  width: 100%;
  max-height: 85vh;
  background: #FAF6EF;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.tree-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #E8DFD0;
  flex-shrink: 0;
}

.tree-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #3D2817;
}

.tree-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tree-progress-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx 0;
}

.tree-step-num {
  font-size: 26rpx;
  color: #722F37;
  font-weight: 600;
}

.tree-back {
  font-size: 26rpx;
  color: #8B7355;
}

.tree-question-area {
  padding: 32rpx;
}

.tree-question {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D2817;
  line-height: 1.5;
}

.tree-options {
  padding: 0 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tree-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #E8DFD0;
}

.tree-option:active {
  border-color: #722F37;
  background: #F5F0E8;
}

.tree-option-text {
  font-size: 30rpx;
  color: #3D2817;
  flex: 1;
}

.tree-option-arrow {
  font-size: 36rpx;
  color: #C19A6B;
  font-weight: 700;
}

/* 决策树结果 */
.tree-result-area {
  padding: 40rpx 32rpx;
  text-align: center;
  flex: 1;
  overflow-y: auto;
}

.tree-result-icon {
  display: block;
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.tree-result-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #3D2817;
  margin-bottom: 32rpx;
}

.tree-recommend-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 32rpx;
  text-align: left;
}

.tree-recommend-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(114, 47, 55, 0.06);
}

.tree-recommend-card:active {
  transform: scale(0.98);
}

.recommend-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.recommend-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D2817;
}

.recommend-desc {
  font-size: 26rpx;
  color: #8B7355;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.recommend-stats {
  display: flex;
  gap: 20rpx;
}

.recommend-stat {
  font-size: 24rpx;
  color: #722F37;
  font-weight: 600;
}

.tree-result-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}
