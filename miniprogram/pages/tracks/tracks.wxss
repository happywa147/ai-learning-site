/* pages/tracks/tracks.wxss */
/* 学习路线页面样式 */

.page-header {
  padding: 20rpx 8rpx 32rpx;
}

/* ========== 路线卡片 ========== */
.track-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(114, 47, 55, 0.08);
}

.track-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.track-info {
  flex: 1;
  margin-right: 20rpx;
}

.track-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.track-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #3D2817;
}

.track-desc {
  font-size: 26rpx;
  color: #8B7355;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.track-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #8B7355;
}

.meta-dot {
  font-size: 24rpx;
  color: #E8DFD0;
}

.track-arrow {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.3s ease;
  flex-shrink: 0;
}

.track-arrow.expanded {
  transform: rotate(90deg);
}

.arrow-icon {
  font-size: 40rpx;
  color: #722F37;
  font-weight: 700;
}

/* ========== 展开区域 ========== */
.track-expanded {
  margin-top: 0;
}

/* ========== 模块列表 ========== */
.modules-list {
  padding-left: 8rpx;
}

.module-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0EBE0;
}

.module-item:last-child {
  border-bottom: none;
}

.module-header {
  display: flex;
  align-items: flex-start;
  width: 100%;
}

.module-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #D4C9B8;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  margin-top: 4rpx;
  transition: all 0.2s ease;
}

.module-check.checked {
  background: #2E7D32;
  border-color: #2E7D32;
}

.check-icon {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.module-content {
  flex: 1;
}

.module-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.module-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D2817;
}

.module-summary {
  display: block;
  font-size: 26rpx;
  color: #8B7355;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.module-duration {
  font-size: 24rpx;
  color: #C19A6B;
}

/* ========== 常见误区 ========== */
.common-errors {
  margin-top: 16rpx;
  padding: 20rpx;
  background: #FFF8F0;
  border-radius: 12rpx;
  border-left: 6rpx solid #F57F17;
}

.errors-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #E65100;
  margin-bottom: 12rpx;
}

.error-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.error-item:last-child {
  margin-bottom: 0;
}

.error-bullet {
  font-size: 24rpx;
  color: #F57F17;
  margin-right: 8rpx;
  line-height: 1.6;
}

.error-text {
  flex: 1;
  font-size: 24rpx;
  color: #8B5E3C;
  line-height: 1.6;
}

/* ========== 自测题区域 ========== */
.quiz-section {
  margin-top: 24rpx;
}

.quiz-intro {
  background: linear-gradient(135deg, #FAF6EF, #F5F0E8);
  border-radius: 16rpx;
  padding: 32rpx;
  text-align: center;
}

.quiz-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #722F37;
  margin-bottom: 12rpx;
}

.quiz-desc {
  display: block;
  font-size: 24rpx;
  color: #8B7355;
  margin-bottom: 24rpx;
}

/* 答题中 */
.quiz-active {
  background: #fff;
  border: 2rpx solid #E8DFD0;
  border-radius: 16rpx;
  padding: 32rpx;
}

.quiz-progress {
  margin-bottom: 20rpx;
}

.quiz-q-num {
  font-size: 24rpx;
  color: #722F37;
  font-weight: 600;
}

.quiz-question {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #3D2817;
  margin-bottom: 28rpx;
  line-height: 1.5;
}

.quiz-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.quiz-option {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FAF6EF;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.quiz-option:active {
  border-color: #722F37;
  background: #F5F0E8;
}

.option-label {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #722F37;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #3D2817;
}

/* 测验结果 */
.quiz-result {
  background: linear-gradient(135deg, #FAF6EF, #FFF8F0);
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  text-align: center;
}

.result-icon {
  display: block;
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.result-score {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  color: #722F37;
  margin-bottom: 16rpx;
}

.result-msg {
  display: block;
  font-size: 26rpx;
  color: #8B7355;
  margin-bottom: 28rpx;
}

/* ========== 底部提示 ========== */
.footer-tip {
  text-align: center;
  padding: 32rpx 40rpx;
}
