/* pages/agent/agent.wxss */
/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(114, 47, 55, 0.06);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--ink);
}

.search-clear {
  padding: 8rpx 16rpx;
  color: var(--muted);
  font-size: 28rpx;
}

/* 分类滚动 */
.category-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 8rpx 0;
}

.category-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  background: #fff;
  color: var(--brown);
  border: 1rpx solid var(--line);
  white-space: nowrap;
}

.category-item.active {
  background: var(--jujube);
  color: #fff;
  border-color: var(--jujube);
}

/* 今日挑战 */
.challenge-card {
  background: linear-gradient(135deg, var(--jujube), var(--brown));
  color: #fff;
}

.challenge-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.challenge-icon {
  font-size: 40rpx;
}

.challenge-title {
  font-size: 32rpx;
  font-weight: 700;
}

.challenge-name {
  font-size: 30rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.challenge-desc {
  font-size: 26rpx;
  opacity: 0.9;
  display: block;
}

.challenge-action {
  margin-top: 16rpx;
  text-align: right;
  font-size: 24rpx;
  opacity: 0.8;
}

/* Agent 网格 */
.agent-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.agent-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(114, 47, 55, 0.08);
}

.agent-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--paper);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.agent-info {
  flex: 1;
  min-width: 0;
}

.agent-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--jujube-dark);
  display: block;
  margin-bottom: 8rpx;
}

.agent-tags {
  display: flex;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.agent-desc {
  font-size: 24rpx;
  color: var(--muted);
}

.agent-copy {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.agent-copy text {
  font-size: 22rpx;
  color: var(--jujube);
  border: 1rpx solid var(--jujube);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

/* 详情弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-content {
  background: #fff;
  width: 100%;
  max-height: 85vh;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--line);
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--jujube-dark);
}

.modal-close {
  font-size: 40rpx;
  color: var(--muted);
  padding: 8rpx;
}

.modal-body {
  padding: 32rpx;
  max-height: 65vh;
}

.agent-emoji-large {
  font-size: 80rpx;
  display: block;
  text-align: center;
  margin-bottom: 24rpx;
}

.agent-description-full {
  font-size: 28rpx;
  color: var(--ink);
  line-height: 1.8;
  display: block;
  margin-bottom: 32rpx;
}

.detail-section {
  margin-bottom: 32rpx;
}

.detail-label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--jujube);
  display: block;
  margin-bottom: 16rpx;
}

.use-cases {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.use-case-item {
  font-size: 26rpx;
  color: var(--ink);
  line-height: 1.6;
}

.prompt-block {
  background: var(--paper);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.prompt-text {
  font-size: 24rpx;
  color: var(--ink);
  line-height: 1.6;
  word-break: break-all;
}

.example-text {
  font-size: 26rpx;
  color: var(--ink);
  line-height: 1.8;
  background: var(--paper);
  padding: 20rpx;
  border-radius: 12rpx;
  display: block;
}
